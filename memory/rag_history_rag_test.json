  {
    "id": 4,
    "command": "Go to the table with the smallest sum of absolute coordinates, circle it with radius 60, then return to the starting point",
    "task_queue": [
      "original_x, original_y = get_robot_pos()",
      "table_obj = parse_obj_name('the table with the smallest sum of absolute coordinates', objects)",
      "table_x, table_y = get_obj_xy(table_obj)",
      "for angle in np.linspace(0, 2 * np.pi, 8, endpoint=False):",
      "    offset_x = 60 * np.cos(angle)",
      "    offset_y = 60 * np.sin(angle)",
      "    move_to_xy(table_x + offset_x, table_y + offset_y)",
      "move_to_xy(original_x, original_y)"
    ]
