  {
    "id": 12,
    "command": "Move in a square of side length 120 around the trash can, when a green block appears, pick it up and put it into the box",
    "task_queue": [
      "trash_can_obj = parse_obj_name('trash can', objects)",
      "trash_can_x, trash_can_y = get_obj_xy(trash_can_obj)",
      "box_obj = parse_obj_name('box', objects)",
      "i = 0",
      "while True:",
      "    if i % 4 == 0:",
      "        move_to_xy(trash_can_x + 60, trash_can_y + 60)",
      "    elif i % 4 == 1:",
      "        move_to_xy(trash_can_x + 60, trash_can_y - 60)",
      "    elif i % 4 == 2:",
      "        move_to_xy(trash_can_x - 60, trash_can_y - 60)",
      "    else:",
      "        move_to_xy(trash_can_x - 60, trash_can_y + 60)",
      "    i += 1",
      "    green_blocks = parse_obj_name('green block', objects)",
      "    if green_blocks:",
      "        for green_block in green_blocks:",
      "            move_to_obj_by_offset(green_block, 0, 0)",
      "            pick_up_obj(green_block)",
      "            move_to_obj_by_offset(box_obj, 0, 0)",
      "            put_down_obj_by_offset(box_obj, 0, 0)"
    ]
  }
